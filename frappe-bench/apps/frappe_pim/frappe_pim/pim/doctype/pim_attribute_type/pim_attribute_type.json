{
  "doctype": "DocType",
  "name": "PIM Attribute Type",
  "module": "PIM",
  "naming_rule": "By fieldname",
  "autoname": "field:type_code",
  "track_changes": 1,
  "engine": "InnoDB",
  "fields": [
    {
      "fieldname": "type_name",
      "fieldtype": "Data",
      "label": "Type Name",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "type_code",
      "fieldtype": "Data",
      "label": "Type Code",
      "reqd": 1,
      "unique": 1,
      "description": "URL-safe identifier"
    },
    {
      "fieldname": "base_type",
      "fieldtype": "Select",
      "label": "Base Type",
      "options": "String\nInteger\nFloat\nBoolean\nDate\nDatetime\nJSON",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "is_standard",
      "fieldtype": "Check",
      "label": "Is Standard",
      "default": 0
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "Is Active",
      "default": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "has_options",
      "fieldtype": "Check",
      "label": "Has Options"
    },
    {
      "fieldname": "supports_unit",
      "fieldtype": "Check",
      "label": "Supports Unit"
    },
    {
      "fieldname": "section_constraints",
      "fieldtype": "Section Break",
      "label": "Constraints"
    },
    {
      "fieldname": "min_value",
      "fieldtype": "Float",
      "label": "Min Value",
      "depends_on": "eval:in_list(['Integer', 'Float'], doc.base_type)"
    },
    {
      "fieldname": "max_value",
      "fieldtype": "Float",
      "label": "Max Value",
      "depends_on": "eval:in_list(['Integer', 'Float'], doc.base_type)"
    },
    {
      "fieldname": "max_length",
      "fieldtype": "Int",
      "label": "Max Length",
      "depends_on": "eval:doc.base_type=='String'"
    },
    {
      "fieldname": "column_break_2",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "validation_regex",
      "fieldtype": "Data",
      "label": "Validation Regex"
    },
    {
      "fieldname": "validation_message",
      "fieldtype": "Data",
      "label": "Validation Message"
    },
    {
      "fieldname": "section_display",
      "fieldtype": "Section Break",
      "label": "Display Settings"
    },
    {
      "fieldname": "input_component",
      "fieldtype": "Data",
      "label": "Input Component"
    },
    {
      "fieldname": "icon",
      "fieldtype": "Data",
      "label": "Icon"
    },
    {
      "fieldname": "default_unit",
      "fieldtype": "Data",
      "label": "Default Unit",
      "depends_on": "supports_unit"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "export": 1,
      "import": 1
    },
    {
      "role": "PIM Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "export": 1
    },
    {
      "role": "PIM User",
      "read": 1
    }
  ],
  "sort_field": "modified",
  "sort_order": "DESC"
}
