{
  "doctype": "DocType",
  "name": "Product Media",
  "module": "PIM",
  "istable": 1,
  "editable_grid": 1,
  
  "fields": [
    {
      "fieldname": "file",
      "fieldtype": "Attach",
      "label": "File",
      "reqd": 1,
      "in_list_view": 1,
      "columns": 3
    },
    {
      "fieldname": "media_type",
      "fieldtype": "Select",
      "label": "Media Type",
      "options": "Main Image\nGallery\nThumbnail\n360 View\nVideo\nDocument\nOther",
      "default": "Gallery",
      "in_list_view": 1,
      "columns": 2
    },
    {
      "fieldname": "title",
      "fieldtype": "Data",
      "label": "Title",
      "in_list_view": 1,
      "columns": 2
    },
    {
      "fieldname": "alt_text",
      "fieldtype": "Data",
      "label": "Alt Text",
      "description": "Alternative text for accessibility"
    },
    {
      "fieldname": "sort_order",
      "fieldtype": "Int",
      "label": "Sort Order",
      "default": 0,
      "in_list_view": 1,
      "columns": 1
    },
    {
      "fieldname": "apply_to_variant",
      "fieldtype": "Link",
      "label": "Apply to Variant Only",
      "options": "Product Variant",
      "description": "Leave empty to apply to all variants"
    },
    {
      "fieldname": "locale",
      "fieldtype": "Link",
      "label": "Locale",
      "options": "Language",
      "description": "Leave empty for all locales"
    },
    {
      "fieldname": "channel",
      "fieldtype": "Link",
      "label": "Channel",
      "options": "Channel",
      "description": "Leave empty for all channels"
    }
  ]
}
